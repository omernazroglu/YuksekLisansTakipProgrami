@{
    Layout = "_Layout";
    ViewData["Title"] = "İlan Düzenle";
    ViewData["PageTitle"] = "İlan Düzenle";
    ViewData["PageSubtitle"] = "Mevcut ilan bilgilerini güncelleyin";
}
@model GraduateAppTracker.Models.UniversityProgram

<div class="form-container">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon form-card-icon--edit">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 17.25V21H6.75L17.81 9.94L14.06 6.19L3 17.25ZM20.71 7.04C21.1 6.65 21.1 6.02 20.71 5.63L18.37 3.29C17.98 2.9 17.35 2.9 16.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z" fill="currentColor"/>
                </svg>
            </div>
            <div>
                <h2 class="form-card-title">İlan Bilgilerini Düzenle</h2>
                <p class="form-card-subtitle">@Model.UniversityName — @Model.DepartmentName</p>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="app-form" id="edit-form">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="CreatedAt" type="hidden" />

            <div class="form-section">
                <h3 class="section-title">Kurum Bilgileri</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="UniversityName" class="form-label">Üniversite Adı <span class="required">*</span></label>
                        <input asp-for="UniversityName" class="form-input" placeholder="örn. Ankara Üniversitesi" />
                        <span asp-validation-for="UniversityName" class="validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DepartmentName" class="form-label">Bölüm / Program Adı <span class="required">*</span></label>
                        <input asp-for="DepartmentName" class="form-input" placeholder="örn. Bilgisayar Mühendisliği" />
                        <span asp-validation-for="DepartmentName" class="validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="section-title">Puan Gereksinimleri</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="MinAlesScore" class="form-label">Minimum ALES Puanı <span class="required">*</span></label>
                        <input asp-for="MinAlesScore" class="form-input" type="number" step="0.01" min="0" max="100" />
                        <span asp-validation-for="MinAlesScore" class="validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ApplicationDate" class="form-label">Son Başvuru Tarihi <span class="required">*</span></label>
                        <input asp-for="ApplicationDate" class="form-input" type="date" />
                        <span asp-validation-for="ApplicationDate" class="validation-error"></span>
                    </div>
                </div>

                <div class="form-group form-group--toggle">
                    <div class="toggle-wrap">
                        <input asp-for="RequiresLanguage" type="checkbox" class="toggle-checkbox" id="requires-language-toggle" />
                        <label for="requires-language-toggle" class="toggle-label">
                            <div class="toggle-track">
                                <div class="toggle-thumb"></div>
                            </div>
                            <span class="toggle-text">Yabancı Dil Puanı Gerekiyor</span>
                        </label>
                    </div>
                </div>

                <div class="form-group" id="language-score-group" style="display: @(Model.RequiresLanguage ? "block" : "none");">
                    <label asp-for="MinLanguageScore" class="form-label">Minimum Yabancı Dil Puanı <span class="required">*</span></label>
                    <input asp-for="MinLanguageScore" class="form-input" type="number" step="0.01" min="0" max="100" id="language-score-input" />
                    <span asp-validation-for="MinLanguageScore" class="validation-error"></span>
                </div>
            </div>

            <div class="form-actions">
                <a asp-controller="Home" asp-action="Index" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3ZM19 19H5V5H16.17L19 7.83V19ZM12 12C10.34 12 9 13.34 9 15C9 16.66 10.34 18 12 18C13.66 18 15 16.66 15 15C15 13.34 13.66 12 12 12ZM6 6H15V10H6V6Z" fill="currentColor"/>
                    </svg>
                    Değişiklikleri Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const toggle = document.getElementById('requires-language-toggle');
    const langGroup = document.getElementById('language-score-group');
    const langInput = document.getElementById('language-score-input');

    function updateLanguageField() {
        if (toggle.checked) {
            langGroup.style.display = 'block';
            langInput.required = true;
        } else {
            langGroup.style.display = 'none';
            langInput.required = false;
        }
    }

    toggle.addEventListener('change', updateLanguageField);
</script>
}
