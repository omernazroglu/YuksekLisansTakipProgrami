@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni İlan Ekle";
    ViewData["PageTitle"] = "Yeni İlan Ekle";
    ViewData["PageSubtitle"] = "Yeni bir üniversite yüksek lisans ilanı oluşturun";
}
@model GraduateAppTracker.Models.UniversityProgram

<div class="form-container">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 3L1 9L12 15L21 10.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z" fill="currentColor"/>
                </svg>
            </div>
            <div>
                <h2 class="form-card-title">İlan Bilgileri</h2>
                <p class="form-card-subtitle">Tüm zorunlu alanları doldurunuz</p>
            </div>
        </div>

        <form asp-action="Create" method="post" class="app-form" id="create-form">
            @Html.AntiForgeryToken()

            <div class="form-section">
                <h3 class="section-title">Kurum Bilgileri</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="UniversityName" class="form-label">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 3L1 9L12 15L21 10.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z" fill="currentColor"/></svg>
                            Üniversite Adı <span class="required">*</span>
                        </label>
                        <input asp-for="UniversityName" class="form-input" placeholder="örn. Ankara Üniversitesi" id="university-name-input" />
                        <span asp-validation-for="UniversityName" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="DepartmentName" class="form-label">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM9 17H7V10H9V17ZM13 17H11V7H13V17ZM17 17H15V13H17V17Z" fill="currentColor"/></svg>
                            Bölüm / Program Adı <span class="required">*</span>
                        </label>
                        <input asp-for="DepartmentName" class="form-input" placeholder="örn. Bilgisayar Mühendisliği" id="department-name-input" />
                        <span asp-validation-for="DepartmentName" class="validation-error"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="section-title">Puan Gereksinimleri</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="MinAlesScore" class="form-label">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM9 17H7V10H9V17ZM13 17H11V7H13V17ZM17 17H15V13H17V17Z" fill="currentColor"/></svg>
                            Minimum ALES Puanı <span class="required">*</span>
                        </label>
                        <input asp-for="MinAlesScore" class="form-input" type="number" step="0.01" min="0" max="100" placeholder="örn. 70.00" id="ales-score-input" />
                        <span asp-validation-for="MinAlesScore" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ApplicationDate" class="form-label">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 3H18V1H16V3H8V1H6V3H5C3.89 3 3.01 3.9 3.01 5L3 19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V8H19V19ZM7 10H12V15H7V10Z" fill="currentColor"/></svg>
                            Son Başvuru Tarihi <span class="required">*</span>
                        </label>
                        <input asp-for="ApplicationDate" class="form-input" type="date" id="application-date-input" />
                        <span asp-validation-for="ApplicationDate" class="validation-error"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="AnnouncementDate" class="form-label">İlan Tarihi</label>
                        <input asp-for="AnnouncementDate" class="form-input" type="date" />
                        <span asp-validation-for="AnnouncementDate" class="validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Quota" class="form-label">Kontenjan Sayısı</label>
                        <input asp-for="Quota" class="form-input" type="number" min="1" placeholder="örn. 15" />
                        <span asp-validation-for="Quota" class="validation-error"></span>
                    </div>
                </div>

                <!-- Language Toggle -->
                <div class="form-group form-group--toggle">
                    <div class="toggle-wrap">
                        <input asp-for="RequiresLanguage" type="checkbox" class="toggle-checkbox" id="requires-language-toggle" />
                        <label for="requires-language-toggle" class="toggle-label">
                            <div class="toggle-track">
                                <div class="toggle-thumb"></div>
                            </div>
                            <span class="toggle-text">Yabancı Dil Puanı Gerekiyor</span>
                        </label>
                    </div>
                    <p class="toggle-hint">Bu seçenek etkinleştirilirse minimum yabancı dil puanı alanı aktif olur.</p>
                </div>

                <!-- Language Score (conditionally shown) -->
                <div class="form-group" id="language-score-group" style="display: none;">
                    <label asp-for="MinLanguageScore" class="form-label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M11.99 2C6.47 2 2 6.48 2 12C2 17.52 6.47 22 11.99 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 11.99 2ZM11 17V15H13V17H11ZM13.07 13.25L12.25 14.08C11.45 14.88 11 15.5 11 17H9C9 15.96 9.45 15.12 10.09 14.49L11.23 13.34C11.55 13.02 11.75 12.58 11.75 12C11.75 10.9 10.85 10 9.75 10C8.65 10 7.75 10.9 7.75 12H5.75C5.75 9.79 7.54 8 9.75 8C11.96 8 13.75 9.79 13.75 12C13.75 12.88 13.4 13.66 13.07 13.25Z" fill="currentColor"/></svg>
                        Minimum Yabancı Dil Puanı <span class="required">*</span>
                    </label>
                    <input asp-for="MinLanguageScore" class="form-input" type="number" step="0.01" min="0" max="100" placeholder="örn. 65.00" id="language-score-input" />
                    <span asp-validation-for="MinLanguageScore" class="validation-error"></span>
                </div>
            </div>

            <div class="form-actions">
                <a asp-controller="Home" asp-action="Index" class="btn btn-ghost" id="cancel-btn">İptal</a>
                <button type="submit" class="btn btn-primary" id="submit-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3ZM19 19H5V5H16.17L19 7.83V19ZM12 12C10.34 12 9 13.34 9 15C9 16.66 10.34 18 12 18C13.66 18 15 16.66 15 15C15 13.34 13.66 12 12 12ZM6 6H15V10H6V6Z" fill="currentColor"/>
                    </svg>
                    İlanı Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const toggle = document.getElementById('requires-language-toggle');
    const langGroup = document.getElementById('language-score-group');
    const langInput = document.getElementById('language-score-input');

    function updateLanguageField() {
        if (toggle.checked) {
            langGroup.style.display = 'block';
            langGroup.classList.add('fade-in');
            langInput.required = true;
        } else {
            langGroup.style.display = 'none';
            langInput.required = false;
            langInput.value = '';
        }
    }

    toggle.addEventListener('change', updateLanguageField);
    updateLanguageField(); // Initialize on page load
</script>
}
