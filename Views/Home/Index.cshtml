@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
    ViewData["PageSubtitle"] = "Tüm yüksek lisans başvurularınızı takip edin";
}
@model IEnumerable<GraduateAppTracker.Models.UniversityProgram>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon stat-icon--total">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM9 17H7V10H9V17ZM13 17H11V7H13V17ZM17 17H15V13H17V17Z" fill="currentColor"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">@ViewBag.TotalCount</span>
            <span class="stat-label">Toplam İlan</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon--active">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z" fill="currentColor"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">@ViewBag.ActiveCount</span>
            <span class="stat-label">Aktif Başvuru</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon--urgent">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11.99 2C6.47 2 2 6.48 2 12C2 17.52 6.47 22 11.99 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 11.99 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20ZM12.5 7H11V13L16.25 16.15L17 14.92L12.5 12.25V7Z" fill="currentColor"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">@ViewBag.UrgentCount</span>
            <span class="stat-label">Acil (7 Gün)</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon--expired">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.47 2 2 6.48 2 12C2 17.52 6.47 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20ZM15.59 7L12 10.59L8.41 7L7 8.41L10.59 12L7 15.59L8.41 17L12 13.41L15.59 17L17 15.59L13.41 12L17 8.41L15.59 7Z" fill="currentColor"/>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-value">@ViewBag.ExpiredCount</span>
            <span class="stat-label">Süresi Dolmuş</span>
        </div>
    </div>
</div>

<!-- Toolbar: Search + Filter + Add -->
<div class="toolbar">
    <form method="get" asp-action="Index" asp-controller="Home" class="search-form">
        <div class="search-input-wrap">
            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15.5 14H14.71L14.43 13.73C15.41 12.59 16 11.11 16 9.5C16 5.91 13.09 3 9.5 3C5.91 3 3 5.91 3 9.5C3 13.09 5.91 16 9.5 16C11.11 16 12.59 15.41 13.73 14.43L14 14.71V15.5L19 20.49L20.49 19L15.5 14ZM9.5 14C7.01 14 5 11.99 5 9.5C5 7.01 7.01 5 9.5 5C11.99 5 14 7.01 14 9.5C14 11.99 11.99 14 9.5 14Z" fill="currentColor"/>
            </svg>
            <input type="text" name="search" id="search-input" placeholder="Üniversite veya bölüm ara..." value="@ViewBag.SearchTerm" class="search-input" />
        </div>
        <input type="hidden" name="filter" value="@ViewBag.ActiveFilter" />
        <button type="submit" class="btn btn-search">Ara</button>
    </form>

    <div class="filter-tabs">
        <a href="@Url.Action("Index", "Home", new { filter = "", search = ViewBag.SearchTerm })" class="filter-tab @(ViewBag.ActiveFilter == null || ViewBag.ActiveFilter == "" ? "filter-tab--active" : "")">Tümü</a>
        <a href="@Url.Action("Index", "Home", new { filter = "active", search = ViewBag.SearchTerm })" class="filter-tab @(ViewBag.ActiveFilter == "active" ? "filter-tab--active" : "")">Aktif</a>
        <a href="@Url.Action("Index", "Home", new { filter = "urgent", search = ViewBag.SearchTerm })" class="filter-tab @(ViewBag.ActiveFilter == "urgent" ? "filter-tab--active" : "")">Acil</a>
        <a href="@Url.Action("Index", "Home", new { filter = "expired", search = ViewBag.SearchTerm })" class="filter-tab @(ViewBag.ActiveFilter == "expired" ? "filter-tab--active" : "")">Süresi Dolmuş</a>
    </div>

    <a asp-controller="Applications" asp-action="Create" class="btn btn-primary" id="add-application-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 13H13V19H11V13H5V11H11V5H13V11H19V13Z" fill="currentColor"/>
        </svg>
        Yeni İlan Ekle
    </a>
</div>

<!-- Programs Grid -->
@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3L1 9L12 15L21 10.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z" fill="currentColor"/>
            </svg>
        </div>
        <h2 class="empty-title">Henüz ilan bulunmuyor</h2>
        <p class="empty-text">@(ViewBag.SearchTerm != null ? "Arama kriterlerinize uygun ilan bulunamadı." : "İlk yüksek lisans ilanını eklemek için butona tıklayın.")</p>
        @if (ViewBag.SearchTerm == null)
        {
            <a asp-controller="Applications" asp-action="Create" class="btn btn-primary">İlk İlanı Ekle</a>
        }
    </div>
}
else
{
    <div class="programs-grid">
        @foreach (var item in Model)
        {
            <div class="program-card @(item.IsExpired ? "card--expired" : item.IsUrgent ? "card--urgent" : "card--active")">
                <div class="card-header">
                    <div class="card-university">
                        <div class="university-avatar">@item.UniversityName[0]</div>
                        <div class="university-info">
                            <h3 class="university-name">@item.UniversityName</h3>
                            <p class="department-name">@item.DepartmentName</p>
                        </div>
                    </div>
                    <div class="card-badge @(item.IsExpired ? "badge--expired" : item.IsUrgent ? "badge--urgent" : "badge--active")">
                        @if (item.IsExpired)
                        {
                            <span>Süresi Doldu</span>
                        }
                        else if (item.IsUrgent)
                        {
                            <span>⚡ @item.DaysRemaining Gün</span>
                        }
                        else
                        {
                            <span>✓ @item.DaysRemaining Gün</span>
                        }
                    </div>
                </div>

                <div class="card-body">
                    <div class="score-row">
                        <div class="score-item">
                            <span class="score-label">ALES</span>
                            <span class="score-value">@item.MinAlesScore</span>
                        </div>
                        @if (item.RequiresLanguage)
                        {
                            <div class="score-item">
                                <span class="score-label">Yabancı Dil</span>
                                <span class="score-value">@item.MinLanguageScore</span>
                            </div>
                        }
                        else
                        {
                            <div class="score-item score-item--na">
                                <span class="score-label">Yabancı Dil</span>
                                <span class="score-value">—</span>
                            </div>
                        }
                    </div>

                    <div class="deadline-row" style="margin-bottom: 8px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M11.99 2C6.47 2 2 6.48 2 12C2 17.52 6.47 22 11.99 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 11.99 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20ZM12.5 7H11V13L16.25 16.15L17 14.92L12.5 12.25V7Z" fill="currentColor"/>
                        </svg>
                        <span>İlan Tarihi: <strong>@(item.AnnouncementDate?.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")) ?? "Belirtilmedi")</strong></span>
                    </div>

                    <div class="deadline-row" style="margin-bottom: 8px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M16 11C17.66 11 19.99 11.89 20 13.5V15H4V13.5C4 11.89 6.34 11 8 11C9.66 11 12 11.89 12 13.5V15H16V13.5C16 11.89 18.34 11 20 11H16ZM12 4C13.66 4 15 5.34 15 7C15 8.66 13.66 10 12 10C10.34 10 9 8.66 9 7C9 5.34 10.34 4 12 4ZM8 4C9.66 4 11 5.34 11 7C11 8.66 9.66 10 8 10C6.34 10 5 8.66 5 7C5 5.34 6.34 4 8 4Z" fill="currentColor"/>
                        </svg>
                        <span>Kontenjan: <strong>@(item.Quota?.ToString() ?? "Belirtilmedi")</strong></span>
                    </div>

                    <div class="deadline-row">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M19 3H18V1H16V3H8V1H6V3H5C3.89 3 3.01 3.9 3.01 5L3 19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V8H19V19ZM7 10H12V15H7V10Z" fill="currentColor"/>
                        </svg>
                        <span>Son Başvuru: <strong>@item.ApplicationDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</strong></span>
                    </div>
                </div>

                <div class="card-actions">
                    <a asp-controller="Applications" asp-action="Details" asp-route-id="@item.Id" class="card-action-btn btn-details">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 4.5C7 4.5 2.73 7.61 1 12C2.73 16.39 7 19.5 12 19.5C17 19.5 21.27 16.39 23 12C21.27 7.61 17 4.5 12 4.5ZM12 17C9.24 17 7 14.76 7 12C7 9.24 9.24 7 12 7C14.76 7 17 9.24 17 12C17 14.76 14.76 17 12 17ZM12 9C10.34 9 9 10.34 9 12C9 13.66 10.34 15 12 15C13.66 15 15 13.66 15 12C15 10.34 13.66 9 12 9Z" fill="currentColor"/>
                        </svg>
                        Detay
                    </a>
                    <a asp-controller="Applications" asp-action="Edit" asp-route-id="@item.Id" class="card-action-btn btn-edit">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 17.25V21H6.75L17.81 9.94L14.06 6.19L3 17.25ZM20.71 7.04C21.1 6.65 21.1 6.02 20.71 5.63L18.37 3.29C17.98 2.9 17.35 2.9 16.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z" fill="currentColor"/>
                        </svg>
                        Düzenle
                    </a>
                    <a asp-controller="Applications" asp-action="Delete" asp-route-id="@item.Id" class="card-action-btn btn-delete">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M6 19C6 20.1 6.9 21 8 21H16C17.1 21 18 20.1 18 19V7H6V19ZM19 4H15.5L14.5 3H9.5L8.5 4H5V6H19V4Z" fill="currentColor"/>
                        </svg>
                        Sil
                    </a>
                </div>
            </div>
        }
    </div>
}
